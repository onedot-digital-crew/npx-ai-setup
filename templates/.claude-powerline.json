{
  "theme": "dark",
  "display": {
    "style": "powerline",
    "charset": "unicode",
    "autoWrap": true,
    "padding": 1,
    "lines": [
      {
        "segments": {
          "model": {
            "enabled": true
          },
          "context": {
            "enabled": true,
            "showPercentageOnly": false,
            "displayStyle": "text",
            "autocompactBuffer": 33000
          },
          "block": {
            "enabled": true,
            "type": "weighted",
            "burnType": "tokens"
          },
          "session": {
            "enabled": true,
            "type": "tokens"
          }
        }
      },
      {
        "segments": {
          "directory": {
            "enabled": true,
            "style": "basename"
          },
          "git": {
            "enabled": true,
            "showSha": false,
            "showWorkingTree": true,
            "showOperation": true
          }
        }
      }
    ]
  },
  "budget": {
    "block": {
      "amount": 200000,
      "type": "tokens",
      "warningThreshold": 75
    }
  }
}
