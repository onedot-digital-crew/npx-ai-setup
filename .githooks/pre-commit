#!/usr/bin/env bash
set -euo pipefail

if [ "${SKIP_PRECOMMIT_ROUTING:-0}" = "1" ]; then
  echo "Skipping routing check (SKIP_PRECOMMIT_ROUTING=1)."
else
  bash tests/routing-check.sh
fi

if [ "${SKIP_PRECOMMIT_FORMAT:-0}" = "1" ]; then
  echo "Skipping format check (SKIP_PRECOMMIT_FORMAT=1)."
else
  bash scripts/format-check.sh
fi

if [ "${SKIP_PRECOMMIT_DRIFT:-0}" = "1" ]; then
  echo "Skipping drift check (SKIP_PRECOMMIT_DRIFT=1)."
else
  bash scripts/template-drift-check.sh
fi
