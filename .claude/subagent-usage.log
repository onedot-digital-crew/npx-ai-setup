 local inode_p inode_s\n  inode_p=$(stat -c %i \"$project_file\" 2>/dev/null || stat -f %i \"$project_file\" 2>/dev/null)\n  inode_s=$(stat -c %i \"$source_file\" 2>/dev/null || stat -f %i \"$source_file\" 2>/dev/null)\n  [[ \"$inode_p\" == \"$inode_s\" ]]\n}\n\n# ── Commands ─────────────────────────────────────────────────────────\n\ncmd_init() {\n  ensure_config\n  if [[ -f \"$SOURCES_FILE\" ]] && grep -qv '^#' \"$SOURCES_FILE\" 2>/dev/null; then\n    info \"Config already exists at $CONFIG_DIR\"\n  fi\n  echo \"\"\n  info \"Next steps:\"\n  echo \"  manage-skills sources add ~/dev/shared-skills\"\n  echo \"  manage-skills sources add ~/dev/perl/shared-skills\"\n  echo \"  cd ~/your-project && manage-skills\"\n}\n\ncmd_sources() {\n  local subcmd=\"${1:-list}\"\n  shift 2>/dev/null || true\n\n  case \"$subcmd\" in\n    list)\n      if [[ ! -f \"$SOURCES_FILE\" ]]; then\n        warn \"No sources configured. Run: manage-skills init\"\n        return\n      fi\n      echo \"${BOLD}Skill sources:${RESET}\"\n      while IFS= read -r line; do\n        [[ -z \"$line\" || \"$line\" =~ ^[[:space:]]*# ]] && continue\n        local expanded\n        expanded=$(expand_path \"$line\")\n        if [[ -d \"$expanded\" ]]; then\n          local count\n          count=$(find \"$expanded\" -maxdepth 2 -name \"*.md\" -type f 2>/dev/null | wc -l)\n          echo \"  ${GREEN}●${RESET} $line  ${DIM}($count skills)${RESET}\"\n        else\n          echo \"  ${RED}●${RESET} $line  ${DIM}(not found)${RESET}\"\n        fi\n      done < \"$SOURCES_FILE\"\n      ;;\n    add)\n      [[ -z \"${1:-}\" ]] && die \"Usage: manage-skills sources add <directory>\"\n      local dir=\"$1\"\n      local expanded\n      expanded=$(expand_path \"$dir\")\n      [[ -d \"$expanded\" ]] || die \"Directory not found: $expanded\"\n      # Check if already in sources\n      if grep -qF \"$dir\" \"$SOURCES_FILE\" 2>/dev/null; then\n        warn \"Already in sources: $dir\"\n        return\n      fi\n      echo \"$dir\" >> \"$SOURCES_FILE\"\n      info \"Added: $dir\"\n      ;;\n    remove)\n      [[ -z \"${1:-}\" ]] && die \"Usage: manage-skills sources remove <directory>\"\n      local dir=\"$1\"\n      local tmp\n      tmp=$(mktemp)\n      grep -vF \"$dir\" \"$SOURCES_FILE\" > \"$tmp\" || true\n      mv \"$tmp\" \"$SOURCES_FILE\"\n      info \"Removed: $dir\"\n      ;;\n    *)\n      die \"Unknown sources command: $subcmd (use list, add, remove)\"\n      ;;\n  esac\n}\n\ncmd_targets() {\n  local subcmd=\"${1:-list}\"\n  shift 2>/dev/null || true\n\n  case \"$subcmd\" in\n    list)\n      echo \"${BOLD}Configured targets:${RESET}\"\n      while IFS=: read -r name path file; do\n        [[ -z \"$name\" || \"$name\" =~ ^[[:space:]]*# ]] && continue\n        echo \"  ${GREEN}$name${RESET}  →  $path/$file\"\n      done < <(read_targets)\n      ;;\n    add)\n      [[ -z \"${1:-}\" || -z \"${2:-}\" || -z \"${3:-}\" ]] && die \"Usage: manage-skills targets add <name> <path> <file>\"\n      echo \"$1:$2:$3\" >> \"$TARGETS_FILE\"\n      info \"Added target: $1 → $2/$3\"\n      ;;\n    *)\n      die \"Unknown targets command: $subcmd (use list, add)\"\n      ;;\n  esac\n}\n\ncmd_list() {\n  local target_name=\"${1:-claude}\"\n  local target_info\n  target_info=$(get_target \"$target_name\")\n  local target_path=\"${target_info%%:*}\"\n  local target_file=\"${target_info##*:}\"\n\n  local project_skills_dir=\"$PWD/$target_path\"\n\n  echo \"${BOLD}Available skills${RESET} ${DIM}(target: $target_name)${RESET}\"\n  echo \"\"\n\n  local has_skills=false\n  while IFS=: read -r source_dir skill_name; do\n    has_skills=true\n    local source_file=\"$source_dir/$skill_name/$target_file\"\n    local project_file=\"$project_skills_dir/$skill_name/$target_file\"\n\n    local short_source=\"$(shorten \"$source_dir\")\"\n    if [[ -f \"$project_file\" ]]; then\n      if is_hardlinked \"$project_file\" \"$source_file\"; then\n        echo \"  ${GREEN}[*]${RESET} $skill_name  ${DIM}← $short_source${RESET}\"\n      else\n        echo \"  ${YELLOW}[~]${RESET} $skill_name  ${DIM}(local copy, not linked)${RESET}\"\n      fi\n    else\n      echo \"  ${DIM}[ ]${RESET} $skill_name  ${DIM}← $short_source${RESET}\"\n    fi\n  done < <(discover_skills \"$target_file\")\n\n  # Show originals (skills in project that aren't from any source)\n  if [[ -d \"$project_skills_dir\" ]]; then\n    for skill_dir in \"$project_skills_dir\"/*/; do\n      [[ -f \"$skill_dir/$target_file\" ]] || continue\n      local skill_name\n      skill_name=$(basename \"$skill_dir\")\n      local is_from_source=false\n      while IFS=: read -r source_dir sname; do\n        [[ \"$sname\" == \"$skill_name\" ]] && is_from_source=true && break\n      done < <(discover_skills \"$target_file\")\n      if ! $is_from_source; then\n        echo \"   ●  $skill_name  ${DIM}(original)${RESET}\"\n      fi\n    done\n  fi\n\n  if ! $has_skills; then\n    warn \"No skills found in any source. Run: manage-skills sources add <dir>\"\n  fi\n\n  echo \"\"\n  echo \"${DIM}Legend: [*] hardlinked  [~] local copy  [ ] available  ● original${RESET}\"\n}\n\ncmd_link() {\n  local target_name=\"claude\"\n  local skills=()\n\n  # Parse args\n  while [[ $# -gt 0 ]]; do\n    case \"$1\" in\n      --target|-t) target_name=\"$2\"; shift 2 ;;\n      *) skills+=(\"$1\"); shift ;;\n    esac\n  done\n\n  [[ ${#skills[@]} -eq 0 ]] && die \"Usage: manage-skills link <skill> [skill...] [--target name]\"\n\n  local target_info\n  target_info=$(get_target \"$target_name\")\n  local target_path=\"${target_info%%:*}\"\n  local target_file=\"${target_info##*:}\"\n  local project_skills_dir=\"$PWD/$target_path\"\n\n  for skill_name in \"${skills[@]}\"; do\n    local found=false\n    while IFS=: read -r source_dir sname; do\n      [[ \"$sname\" == \"$skill_name\" ]] || continue\n      found=true\n      local source_file=\"$source_dir/$skill_name/$target_file\"\n      local dest_dir=\"$project_skills_dir/$skill_name\"\n      local dest_file=\"$dest_dir/$target_file\"\n\n      if is_hardlinked \"$dest_file\" \"$source_file\" 2>/dev/null; then\n        info \"$skill_name: already linked\"\n        break\n      fi\n\n      mkdir -p \"$dest_dir\"\n      rm -f \"$dest_file\"\n      ln \"$source_file\" \"$dest_file\"\n      echo \"  ${GREEN}linked${RESET} $skill_name ← $source_dir\"\n      break\n    done < <(discover_skills \"$target_file\")\n\n    if ! $found; then\n      warn \"$skill_name: not found in any source\"\n    fi\n  done\n}\n\ncmd_unlink() {\n  local target_name=\"claude\"\n  local skills=()\n\n  while [[ $# -gt 0 ]]; do\n    case \"$1\" in\n      --target|-t) target_name=\"$2\"; shift 2 ;;\n      *) skills+=(\"$1\"); shift ;;\n    esac\n  done\n\n  [[ ${#skills[@]} -eq 0 ]] && die \"Usage: manage-skills unlink <skill> [skill...] [--target name]\"\n\n  local target_info\n  target_info=$(get_target \"$target_name\")\n  local target_path=\"${target_info%%:*}\"\n  local target_file=\"${target_info##*:}\"\n  local project_skills_dir=\"$PWD/$target_path\"\n\n  for skill_name in \"${skills[@]}\"; do\n    local dest_dir=\"$project_skills_dir/$skill_name\"\n    if [[ -d \"$dest_dir\" ]]; then\n      rm -rf \"$dest_dir\"\n      echo \"  ${RED}unlinked${RESET} $skill_name\"\n    else\n      warn \"$skill_name: not found in project\"\n    fi\n  done\n}\n\ncmd_sync() {\n  local target_name=\"${1:-claude}\"\n  local target_info\n  target_info=$(get_target \"$target_name\")\n  local target_path=\"${target_info%%:*}\"\n  local target_file=\"${target_info##*:}\"\n  local project_skills_dir=\"$PWD/$target_path\"\n  local fixed=0 ok=0 missing=0\n\n  echo \"${BOLD}Syncing hardlinks${RESET} ${DIM}(target: $target_name)${RESET}\"\n\n  while IFS=: read -r source_dir skill_name; do\n    local source_file=\"$source_dir/$skill_name/$target_file\"\n    local dest_dir=\"$project_skills_dir/$skill_name\"\n    local dest_file=\"$dest_dir/$target_file\"\n\n    [[ -d \"$dest_dir\" ]] || continue  # only sync skills already in the project\n\n    if is_hardlinked \"$dest_file\" \"$source_file\" 2>/dev/null; then\n      ok=$((ok + 1))\n    else\n      # File exists but is a copy, not a hardlink — re-link\n      mkdir -p \"$dest_dir\"\n      rm -f \"$dest_file\"\n      ln \"$source_file\" \"$dest_file\"\n      echo \"  ${GREEN}relinked${RESET} $skill_name\"\n      fixed=$((fixed + 1))\n    fi\n  done < <(discover_skills \"$target_file\")\n\n  echo \"\"\n  echo \"  ${GREEN}$ok${RESET} ok, ${YELLOW}$fixed${RESET} relinked\"\n}\n\ncmd_check() {\n  local target_name=\"${1:-claude}\"\n  local target_info\n  target_info=$(get_target \"$target_name\")\n  local target_path=\"${target_info%%:*}\"\n  local target_file=\"${target_info##*:}\"\n  local project_skills_dir=\"$PWD/$target_path\"\n  local ok=0 copies=0 originals=0\n\n  echo \"${BOLD}Checking hardlinks${RESET} ${DIM}(target: $target_name)${RESET}\"\n\n  [[ -d \"$project_skills_dir\" ]] || die \"No skills directory: $project_skills_dir\"\n\n  # Build source map first (skill_name → source_dir)\n  local -A source_map=()\n  while IFS=: read -r source_dir skill_name; do\n    source_map[$skill_name]=\"$source_dir\"\n  done < <(discover_skills \"$target_file\")\n\n  for skill_dir in \"$project_skills_dir\"/*/; do\n    [[ -f \"$skill_dir/$target_file\" ]] || continue\n    local skill_name\n    skill_name=$(basename \"$skill_dir\")\n\n    if [[ -n \"${source_map[$skill_name]:-}\" ]]; then\n      local source_file=\"${source_map[$skill_name]}/$skill_name/$target_file\"\n      if is_hardlinked \"$skill_dir/$target_file\" \"$source_file\"; then\n        ok=$((ok + 1))\n      else\n        echo \"  ${YELLOW}[~]${RESET} $skill_name  ${DIM}(copy, expected hardlink from ${source_map[$skill_name]})${RESET}\"\n        copies=$((copies + 1))\n      fi\n    else\n      originals=$((originals + 1))\n    fi\n  done\n\n  echo \"\"\n  echo \"  ${GREEN}$ok${RESET} linked, ${YELLOW}$copies${RESET} copies, $originals originals\"\n  if [[ $copies -gt 0 ]]; then\n    echo \"  Run ${BOLD}manage-skills sync${RESET} to fix copies\"\n  fi\n}\n\n# ── Interactive Mode (fzf or fallback) ───────────────────────────────\n\ncmd_interactive() {\n  local target_name=\"${1:-claude}\"\n  local target_info\n  target_info=$(get_target \"$target_name\")\n  local target_path=\"${target_info%%:*}\"\n  local target_file=\"${target_info##*:}\"\n  local project_skills_dir=\"$PWD/$target_path\"\n\n  # Build skill list\n  local -a all_skills=()\n  local -a all_sources=()\n  local -a all_states=()\n\n  while IFS=: read -r source_dir skill_name; do\n    local source_file=\"$source_dir/$skill_name/$target_file\"\n    local dest_file=\"$project_skills_dir/$skill_name/$target_file\"\n    local state=\"available\"\n\n    if [[ -f \"$dest_file\" ]]; then\n      if is_hardlinked \"$dest_file\" \"$source_file\" 2>/dev/null; then\n        state=\"linked\"\n      else\n        state=\"copy\"\n      fi\n    fi\n\n    all_skills+=(\"$skill_name\")\n    all_sources+=(\"$source_dir\")\n    all_states+=(\"$state\")\n  done < <(discover_skills \"$target_file\")\n\n  if [[ ${#all_skills[@]} -eq 0 ]]; then\n    die \"No skills found. Configure sources first: manage-skills sources add <dir>\"\n  fi\n\n  # Try fzf\n  if command -v fzf &>/dev/null; then\n    _interactive_fzf \"$target_name\" \"$target_path\" \"$target_file\" \"$project_skills_dir\"\n  else\n    _interactive_basic \"$target_name\" \"$target_path\" \"$target_file\" \"$project_skills_dir\"\n  fi\n}\n\n_interactive_fzf() {\n  local target_name=\"$1\" target_path=\"$2\" target_file=\"$3\" project_skills_dir=\"$4\"\n\n  # Build fzf input\n  local fzf_input=\"\"\n  local -a preselected=()\n  local idx=0\n\n  while IFS=: read -r source_dir skill_name; do\n    local source_file=\"$source_dir/$skill_name/$target_file\"\n    local dest_file=\"$project_skills_dir/$skill_name/$target_file\"\n    local marker=\"\"\n\n    if [[ -f \"$dest_file\" ]] && is_hardlinked \"$dest_file\" \"$source_file\" 2>/dev/null; then\n      preselected+=(\"$skill_name\")\n    fi\n\n    local short_source=\"$(shorten \"$source_dir\")\"\n    fzf_input+=\"$skill_name  ← $short_source\"$'\\n'\n    ((idx++))\n  done < <(discover_skills \"$target_file\")\n\n  # Build preselect args for fzf -- we pass the already-linked ones\n  local selected\n  selected=$(echo -n \"$fzf_input\" | fzf --multi --ansi \\\n    --header=\"Toggle skills with TAB, confirm with ENTER\" \\\n    --prompt=\"Skills for $(basename \"$PWD\") > \" \\\n    --preview=\"head -20 {+1}/$target_file 2>/dev/null || echo 'Not yet linked'\" \\\n    --preview-window=right:50%:wrap \\\n    $(for s in \"${preselected[@]}\"; do echo -n \" --bind=start:select-all\"; break; done) \\\n    | awk '{print $1}') || return 0\n\n  # Determine what to link and unlink\n  local -a to_link=()\n  local -a to_unlink=()\n\n  while IFS=: read -r source_dir skill_name; do\n    local dest_file=\"$project_skills_dir/$skill_name/$target_file\"\n    local source_file=\"$source_dir/$skill_name/$target_file\"\n    local is_selected=false\n    while IFS= read -r sel; do\n      [[ \"$sel\" == \"$skill_name\" ]] && is_selected=true && break\n    done <<< \"$selected\"\n\n    local is_linked=false\n    if [[ -f \"$dest_file\" ]] && is_hardlinked \"$dest_file\" \"$source_file\" 2>/dev/null; then\n      is_linked=true\n    fi\n\n    if $is_selected && ! $is_linked; then\n      to_link+=(\"$skill_name\")\n    elif ! $is_selected && $is_linked; then\n      to_unlink+=(\"$skill_name\")\n    fi\n  done < <(discover_skills \"$target_file\")\n\n  # Apply\n  for s in \"${to_link[@]}\"; do\n    cmd_link \"$s\" --target \"$target_name\"\n  done\n  for s in \"${to_unlink[@]}\"; do\n    cmd_unlink \"$s\" --target \"$target_name\"\n  done\n}\n\n_interactive_basic() {\n  local target_name=\"$1\" target_path=\"$2\" target_file=\"$3\" project_skills_dir=\"$4\"\n\n  local -a names=() sources=() states=()\n\n  while IFS=: read -r source_dir skill_name; do\n    local source_file=\"$source_dir/$skill_name/$target_file\"\n    local dest_file=\"$project_skills_dir/$skill_name/$target_file\"\n    local state=\"[ ]\"\n\n    if [[ -f \"$dest_file\" ]]; then\n      if is_hardlinked \"$dest_file\" \"$source_file\" 2>/dev/null; then\n        state=\"[*]\"\n      else\n        state=\"[~]\"\n      fi\n    fi\n\n    names+=(\"$skill_name\")\n    sources+=(\"$source_dir\")\n    states+=(\"$state\")\n  done < <(discover_skills \"$target_file\")\n\n  local -a original_states=(\"${states[@]}\")\n\n  while true; do\n    clear 2>/dev/null || true\n    echo \"${BOLD}Skills for $(basename \"$PWD\")${RESET}\"\n    echo \"\"\n\n    for i in \"${!names[@]}\"; do\n      local num=$((i + 1))\n      local short_source=\"$(shorten \"${sources[$i]}\")\"\n      if [[ \"${states[$i]}\" == \"[*]\" ]]; then\n        printf \"  ${GREEN}%2d) %s${RESET} %-30s ${DIM}← %s${RESET}\\n\" \"$num\" \"${states[$i]}\" \"${names[$i]}\" \"$short_source\"\n      else\n        printf \"  %2d) %s %-30s ${DIM}← %s${RESET}\\n\" \"$num\" \"${states[$i]}\" \"${names[$i]}\" \"$short_source\"\n      fi\n    done\n\n    echo \"\"\n    echo \"${DIM}Enter number to toggle, 'a' to apply changes, 'q' to quit${RESET}\"\n    read -rp \"> \" input\n\n    case \"$input\" in\n      q|Q) return ;;\n      a|A)\n        for i in \"${!names[@]}\"; do\n          if [[ \"${states[$i]}\" != \"${original_states[$i]}\" ]]; then\n            if [[ \"${states[$i]}\" == \"[*]\" ]]; then\n              cmd_link \"${names[$i]}\" --target \"$target_name\"\n            else\n              cmd_unlink \"${names[$i]}\" --target \"$target_name\"\n            fi\n          fi\n        done\n        return\n        ;;\n      *)\n        if [[ \"$input\" =~ ^[0-9]+$ ]] && (( input >= 1 && input <= ${#names[@]} )); then\n          local idx=$((input - 1))\n          if [[ \"${states[$idx]}\" == \"[*]\" ]]; then\n            states[$idx]=\"[ ]\"\n          else\n            states[$idx]=\"[*]\"\n          fi\n        fi\n        ;;\n    esac\n  done\n}\n\n# ── Main ─────────────────────────────────────────────────────────────\n\ncmd_help() {\n  echo \"${BOLD}manage-skills${RESET} v$VERSION — Hardlink-based skill sharing across projects\n\n${BOLD}USAGE${RESET}\n  manage-skills                    Interactive mode (fzf or menu)\n  manage-skills list               List all available skills\n  manage-skills link <skill>...    Hardlink skills into current project\n  manage-skills unlink <skill>...  Remove skills from current project\n  manage-skills sync               Re-hardlink stale copies\n  manage-skills check              Verify hardlink integrity\n\n${BOLD}CONFIG${RESET}\n  manage-skills init               Create ~/.manage-skills/ config\n  manage-skills sources            List source directories\n  manage-skills sources add <dir>  Add a skill source directory\n  manage-skills sources remove <dir>\n  manage-skills targets            List configured targets\n  manage-skills targets add <name> <path> <file>\n\n${BOLD}OPTIONS${RESET}\n  --target, -t <name>   Target type (default: claude)\n  --version             Show version\n  --help, -h            Show this help\n\n${BOLD}CONFIG FILES${RESET}\n  ~/.manage-skills/sources   Skill source directories (one per line)\n  ~/.manage-skills/targets   Target definitions (name:path:file)\n\n${BOLD}EXAMPLES${RESET}\n  manage-skills init\n  manage-skills sources add ~/dev/shared-skills\n  manage-skills sources add ~/dev/perl/shared-skills\n  cd ~/my-project && manage-skills          # interactive\n  manage-skills link perl-moo dbio-core     # link specific skills\n  manage-skills check                       # verify everything\"\n}\n\nensure_config\n\ncase \"${1:-}\" in\n  \"\")           cmd_interactive ;;\n  init)         cmd_init ;;\n  list)         shift; cmd_list \"$@\" ;;\n  link)         shift; cmd_link \"$@\" ;;\n  unlink)       shift; cmd_unlink \"$@\" ;;\n  sync)         shift; cmd_sync \"$@\" ;;\n  check)        shift; cmd_check \"$@\" ;;\n  sources)      shift; cmd_sources \"$@\" ;;\n  targets)      shift; cmd_targets \"$@\" ;;\n  --version)    echo \"manage-skills $VERSION\" ;;\n  --help|-h)    cmd_help ;;\n  *)            die \"Unknown command: $1. Run manage-skills --help\" ;;\nesac\n```\n\nThe script is 644 lines total, as shown in line 1 of the output (the \"32\" indicates it's a 32-line file, but that was just the line count output - the actual file is 644 lines as shown by the line numbers)."}
